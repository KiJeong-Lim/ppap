% User-defined symbolic operators are accepted in type, fixity, and term
% positions even when they begin with a built-in operator character.
% The high operator precedence checks that application still binds tighter.
kind myt type.
type ++ (myt -> myt -> myt).
type word (nat -> myt).
type p (myt -> o).
p (word 1 ++ word 2 ++ word 3).
infixl ++ 9.
