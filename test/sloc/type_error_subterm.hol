% Section 2.6.1 (T3): a type error attributes its SLoc to the smallest
% enclosing annotated construct, not to the whole clause.  Here
% `appendStr` expects two strings, but the second argument is a `nat`.
% The error must point at column of the bad argument, not the whole
% `appendStr` application.
kind myStr type.
type appendStr (string -> string -> myStr -> o).
appendStr "a" 7 _.
