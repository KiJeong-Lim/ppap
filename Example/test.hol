kind i (type).

type f (i -> i -> i).

type main (i -> i) -> (i -> i -> i) -> (i -> i -> i) -> o.
main X Y Z :- pi c\ pi d\ X c = f (Y c d) (Z c c).

% Example.test> ?- main X Y Z.
% Example.test> The answer substitution is:
% Example.test> X := W_1\ f (?V_58 W_1) (?V_59 W_1 W_1).
% Example.test> Y := W_1\ W_2\ ?V_58 W_1.
% Example.test> Z := ?V_59.
